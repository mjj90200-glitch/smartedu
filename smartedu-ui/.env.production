# ============================================================
# SmartEdu-Platform 生产环境配置文件
# ============================================================
# 此文件在 npm run build 时被 Vite 读取
# 变量会以 VITE_ 开头暴露给应用代码
# ============================================================

# 生产环境 API 基础路径
# Docker 部署时，前端通过 nginx 反向代理访问后端 API
# 所有 /api 开头的请求会被 nginx 转发到后端服务
VITE_API_BASE_URL=/api

# 应用标题
VITE_APP_TITLE=SmartEdu-Platform 智慧教育平台

# 是否启用生产环境日志
VITE_PROD_LOG=false
